# attest_ai Production Environment Configuration for SecretVM
# 
# IMPORTANT: This file contains sensitive production credentials
# - Never commit this file to version control
# - Upload separately to SecretVM using: secretvm-cli vm upload-env <vm_id> .env.production
# - SecretVM will encrypt this file automatically

# =============================================================================
# SECRET AI CONFIGURATION (REQUIRED)
# =============================================================================
# Master API key for Secret AI SDK
# Format: Base64-encoded key from Secret Network documentation
SECRET_AI_API_KEY=bWFzdGVyQHNjcnRsYWJzLmNvbTpTZWNyZXROZXR3b3JrTWFzdGVyS2V5X18yMDI1

# Cache TTL for Secret AI instance discovery (seconds)
SECRET_AI_DISCOVERY_CACHE_TTL=3600

# =============================================================================
# ARWEAVE CONFIGURATION (REQUIRED)
# =============================================================================
# Arweave wallet in JWK (JSON Web Key) format
# Generate at: https://arweave.app/wallet or use existing wallet export
# CRITICAL: Must be valid JWK JSON, not mnemonic phrase
ARWEAVE_WALLET_JWK={"kty":"RSA","e":"AQAB","n":"YOUR_WALLET_N_VALUE","d":"YOUR_WALLET_D_VALUE","p":"YOUR_P_VALUE","q":"YOUR_Q_VALUE","dp":"YOUR_DP_VALUE","dq":"YOUR_DQ_VALUE","qi":"YOUR_QI_VALUE"}

# Arweave gateway URL (default: official gateway)
ARWEAVE_GATEWAY=https://arweave.net

# Enable/disable Arweave uploads
ENABLE_ARWEAVE_UPLOAD=true

# Mock transactions when wallet has insufficient funds
MOCK_UNFUNDED_TRANSACTIONS=true

# =============================================================================
# SECRETVM ATTESTATION CONFIGURATION
# =============================================================================
# Self-attestation URL (SecretVM provides this at localhost:29343)
SELF_ATTESTATION_URL=http://localhost:29343

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================
# Application host and port
APP_HOST=0.0.0.0
APP_PORT=8000

# Production mode (set to false only for debugging)
APP_DEBUG=false

# =============================================================================
# CACHING CONFIGURATION
# =============================================================================
# Cache TTL for attestation data (seconds)
# Recommendation: 300 seconds (5 minutes) for production
CACHE_TTL_SECONDS=300

# =============================================================================
# MOCK CONFIGURATION
# =============================================================================
# Mock Secret AI attestation if service unavailable
# Recommendation: false for production, true for testing
MOCK_SECRET_AI_ATTESTATION=false

# Mock Arweave uploads (overrides smart mock logic)
# Recommendation: false (let smart logic handle based on wallet funding)
MOCK_ARWEAVE_UPLOAD=false

# =============================================================================
# PRODUCTION OPTIMIZATION
# =============================================================================
# Log level for production
LOG_LEVEL=WARNING

# Enable performance monitoring
ENABLE_MONITORING=true

# Maximum concurrent requests
MAX_CONCURRENT_REQUESTS=50

# Request timeout (seconds)
REQUEST_TIMEOUT=30

# =============================================================================
# SECRETVM-SPECIFIC CONFIGURATION
# =============================================================================
# Environment detection
DEPLOYMENT_ENVIRONMENT=production
SECRETVM_DEPLOYMENT=true

# Resource constraints
MAX_MEMORY_MB=1024
MAX_CPU_PERCENT=80

# Health check configuration
HEALTH_CHECK_INTERVAL=30
HEALTH_CHECK_TIMEOUT=10
HEALTH_CHECK_RETRIES=3

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================
# CORS origins (comma-separated)
CORS_ORIGINS=*

# Rate limiting
RATE_LIMIT_PER_MINUTE=100

# Security headers
ENABLE_SECURITY_HEADERS=true

# =============================================================================
# NOTES FOR SECRETVM DEPLOYMENT
# =============================================================================
#
# 1. CREDENTIAL MANAGEMENT:
#    - Replace all placeholder values with actual production credentials
#    - Verify SECRET_AI_API_KEY is the correct master key
#    - Ensure ARWEAVE_WALLET_JWK is properly formatted JWK (not mnemonic)
#
# 2. SECRETVM UPLOAD:
#    - Use: secretvm-cli vm upload-env <vm_id> .env.production
#    - File will be automatically encrypted by SecretVM
#    - Environment variables will be available to the container
#
# 3. VALIDATION:
#    - Test configuration locally first
#    - Verify Arweave wallet has sufficient funds for testing
#    - Confirm Secret AI API key has proper permissions
#
# 4. MONITORING:
#    - Check application logs after deployment
#    - Monitor health endpoint: https://<vm_url>:8000/health
#    - Validate all services are properly initialized
#
# 5. SECURITY:
#    - Never commit this file to version control
#    - Rotate credentials regularly
#    - Monitor for any credential exposure in logs
#
# =============================================================================